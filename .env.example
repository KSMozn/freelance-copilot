# Postgres
POSTGRES_USER=upwork
POSTGRES_PASSWORD=upwork
POSTGRES_DB=upwork_intel
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-this-is-a-dev-only-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENVIRONMENT=development

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

# AI providers (Phase 2)
# AI_PROVIDER: 'mock' (default, no network), 'openai', or 'claude'.
# 'mock' is a deterministic heuristic provider — useful for local dev, tests, and
# offline demos. Switch to 'openai' or 'claude' once you have a key.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Using Groq (OpenAI-compatible) -----------------------------------------
# Groq speaks the OpenAI Chat Completions protocol, so the 'openai' provider
# above works as-is with a base-URL override:
#
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=<your-groq-key>
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=openai/gpt-oss-120b   # primary
#   # alternatives: llama-3.3-70b-versatile, openai/gpt-oss-20b
# ---------------------------------------------------------------------------

# Embeddings (Phase 3) — used for portfolio↔job semantic matching.
# EMBEDDING_PROVIDER: 'mock' (deterministic feature-hash, no network) or 'openai'.
# OpenAI embeddings reuse OPENAI_API_KEY.
EMBEDDING_PROVIDER=mock
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Email (Phase A) — OTP signup/sign-in + password reset.
# Development: 'mock' (default) — emails are CAPTURED, never sent: they land
#   in backend/var/dev-emails.jsonl and are exposed at GET /api/v1/dev/emails
#   (development+mock only) + shown by the SPA's dev helper boxes. Nothing
#   ever reaches a real inbox locally.
# Production: 'resend' is REQUIRED (staging/production refuse to boot on
#   'mock'); set RESEND_API_KEY and verify EMAIL_FROM_ADDRESS in the Resend
#   dashboard before sending real mail.
EMAIL_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME=Careero
APP_NAME=Careero
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_15MIN=3
# Per-IP request-code budget per minute. 30 is the dev-stack value (the e2e
# suite signs many unique accounts in from one IP); production leaves this
# unset and gets the app default of 8.
OTP_REQUEST_IP_LIMIT_PER_MIN=30
# Forgot-password links are single-use; 15-30 minutes is the accepted window.
PASSWORD_RESET_EXPIRES_MINUTES=30

# Base URLs used in emails / redirects
FRONTEND_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5173

# JWT / impersonation
ALGORITHM=HS256
IMPERSONATION_TOKEN_EXPIRE_MINUTES=30

# Blob storage: 'local' writes to UPLOADS_DIR; 'gcs' uses the bucket (Cloud Run).
BLOB_STORE=local
UPLOADS_DIR=var/uploads
GCS_UPLOADS_BUCKET=

# GitHub API (repository scanning — dormant professional surface + career pack review)
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com

# Secret for the machine-triggered daily-report task (X-Task-Secret header).
# Fail-closed outside development: the endpoint returns 503 if unset.
REPORT_TASK_SECRET=

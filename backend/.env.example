POSTGRES_USER=upwork
POSTGRES_PASSWORD=upwork
POSTGRES_DB=upwork_intel
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development

# AI providers (Phase 2). Default to 'mock' so the backend starts without keys.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Embeddings (Phase 3). Reuses OPENAI_API_KEY when EMBEDDING_PROVIDER=openai.
EMBEDDING_PROVIDER=mock
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# JWT / impersonation
ALGORITHM=HS256
IMPERSONATION_TOKEN_EXPIRE_MINUTES=30

# OpenAI-compatible base URL — point at Groq/other providers if desired.
OPENAI_BASE_URL=https://api.openai.com/v1

# Blob storage: 'local' writes to UPLOADS_DIR; 'gcs' uses the bucket (Cloud Run).
BLOB_STORE=local
UPLOADS_DIR=var/uploads
GCS_UPLOADS_BUCKET=

# GitHub API (repository scanning — dormant professional surface + career pack review)
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com

# Email + OTP sign-in. 'mock' writes to var/dev-emails.jsonl (dev only —
# refused in staging/production).
EMAIL_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME=Careero
APP_NAME=Careero
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_15MIN=3

# Base URLs used in emails / redirects
FRONTEND_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5173

# Secret for the machine-triggered daily-report task (X-Task-Secret header).
# Fail-closed outside development: the endpoint returns 503 if unset.
REPORT_TASK_SECRET=

server {
    listen ${PORT};
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # Cloud Run terminates TLS and forwards to this container on http:8080, so
    # nginx would otherwise build redirect Location headers as
    # http://careero.app:8080/... . Emit relative redirects instead — the
    # browser resolves them against the real https://careero.app origin.
    absolute_redirect off;
    port_in_redirect off;

    # Security headers (mirrors the app hardening). This site has no
    # executable JS of its own; the CSP allows inline JSON-LD structured data
    # and the external stylesheet, nothing else.
    #
    # NOTE: caching below uses `expires` (not `add_header Cache-Control`) on
    # purpose — an `add_header` inside a location would reset nginx's header
    # inheritance and silently drop these security headers. `expires` doesn't.
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    # script-src / connect-src allow Cloudflare Web Analytics (cookieless).
    add_header Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https://cloudflareinsights.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" always;

    # 301 redirects: old slugs consolidated into their new canonical URLs so
    # nothing is double-indexed after the SEO restructure.
    location = /ai-cv-builder { return 301 /ai-cv-builder-for-students; }
    location = /write-cv-for-students { return 301 /create-cv-for-students; }
    location = /linkedin-profile-for-students { return 301 /guides/linkedin-profile-for-students; }
    location = /github-profile-for-students { return 301 /guides/github-profile-for-students; }
    location = /blog/how-to-describe-student-projects { return 301 /guides/how-to-write-projects-in-a-cv; }
    location = /blog/how-to-write-cv-with-no-experience { return 301 /guides/student-cv-with-no-experience; }

    # Homepage.
    location = / {
        try_files /index.html =404;
        expires -1;
    }

    # Pretty URLs served DIRECTLY (200, no redirect): /student-cv-builder maps
    # to /student-cv-builder/index.html. Canonicals are the no-trailing-slash
    # form, so serving them without a 301 keeps the canonical == the live URL.
    # Unknown paths return a real 404 (never rewritten to home).
    location / {
        try_files $uri $uri/index.html $uri/ =404;
        expires -1;
    }

    # Static assets aren't content-hashed, so cache briefly and revalidate.
    location ~* \.(css|svg|png|jpg|jpeg|ico|webp|woff2?)$ {
        expires 1h;
    }

    location = /robots.txt { expires 1h; }
    location = /sitemap.xml { expires 1h; }

    gzip on;
    gzip_types text/plain text/css application/javascript application/json application/xml image/svg+xml;
    gzip_min_length 1024;
}

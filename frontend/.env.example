# Backend API base URL used by src/app/apiClient.ts as the dev fallback.
# In deployed environments the URL is resolved at runtime from the frontend
# hostname (careero.app / personaarmory.com / *.run.app pairing) — this
# variable only matters for local development on hosts that match none of
# those patterns.
VITE_API_BASE_URL=http://localhost:8000/api/v1
